#!/usr/bin/env bash
# fmcp launcher — MCP stdio bridge for VitaSound Forth tooling.
#
# Conventions (shared with bin/fmix, bin/flint, bin/fcov):
#   - $<TOOL>_HOME  — tool source tree (default $HOME/<tool>)
#   - $<TOOL>_CMD   — subcommand
#   - $<TOOL>_ARG   — positional argument string
#
: "${FMCP_HOME:=$HOME/fmcp}"
GFORTH="${GFORTH:-gforth}"
GFORTH_RSTACK="${GFORTH_RSTACK:-65536}"
GFORTH_DSTACK="${GFORTH_DSTACK:-65536}"
# GFORTH must be a binary path for serve (not "gforth -flags"). Take first word only.
GFORTH_BIN="${GFORTH%% *}"
if ! GFORTH_BIN="$(command -v "$GFORTH_BIN" 2>/dev/null)"; then
    GFORTH_BIN=""
fi
unset GFORTHPATH

reset_tty() {
    local tty_path
    tty_path=$(tty 2>/dev/null || true)
    case "$tty_path" in ""|"not a tty") return ;; esac
    [ -r "$tty_path" ] && [ -w "$tty_path" ] || return
    stty sane < "$tty_path" 2>/dev/null || true
    printf '\033[?2004l' > "$tty_path" 2>/dev/null || true
    local _ch
    while IFS= read -r -s -t 0.02 -n 1 _ch < "$tty_path"; do :; done
}

if [ "${1:-}" != "serve" ]; then
    reset_tty
fi

if [ $# -eq 0 ]; then
    FMCP_CMD=help
    FMCP_ARG=
else
    FMCP_CMD=$1
    shift
    if [ "$FMCP_CMD" = "test" ]; then
        FMCP_TEST_ISOLATED=1
        while [ $# -gt 0 ]; do
            case "$1" in
                --isolated) FMCP_TEST_ISOLATED=1; shift ;;
                --shared)   FMCP_TEST_ISOLATED=0; shift ;;
                --)         shift; break ;;
                --*)
                    echo "[ERROR] Unknown test flag: $1" >&2
                    exit 1
                    ;;
                *) break ;;
            esac
        done
        export FMCP_TEST_ISOLATED
    fi
    FMCP_ARG=$*
fi
export FMCP_HOME FMCP_CMD FMCP_ARG

if [ "$FMCP_CMD" = "test" ] && [ -z "${FMCP_LOG+x}" ]; then
    export FMCP_LOG=0
fi

fmcp_log_enabled() {
    case "${FMCP_LOG:-}" in
        ''|0|off|false) return 1 ;;
        *) return 0 ;;
    esac
}

fmcp_log_resolve() {
    case "${FMCP_LOG:-}" in
        1|on) printf '%s' "$FMCP_HOME/.fmcp/serve.log" ;;
        *) printf '%s' "$FMCP_LOG" ;;
    esac
}

if [ "$FMCP_CMD" = "serve" ]; then
    if fmcp_log_enabled; then
        FMCP_LOG_FILE="$(fmcp_log_resolve)"
        mkdir -p "$(dirname "$FMCP_LOG_FILE")"
        log_exit() {
            local st=$?
            printf '[%s] SESSION_END shell pid=%s status=%s\n' \
                "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "$st" >>"$FMCP_LOG_FILE"
        }
        trap log_exit EXIT
    fi
    if [ -n "${FMCP_DEBUG:-}" ]; then
        stderr_dest="/tmp/fmcp-stderr-$$.log"
    else
        stderr_dest="/dev/null"
    fi
    if [ -z "$GFORTH_BIN" ]; then
        echo "[ERROR] fmcp serve: Gforth not found (GFORTH='${GFORTH}'). Set GFORTH to the gforth binary path." >&2
        exit 127
    fi
    set +e
    # Long MCP sessions (feco batches, many mcp_ping/fcov_run calls) need a larger return stack.
    "$GFORTH_BIN" -d "$GFORTH_DSTACK" -r "$GFORTH_RSTACK" \
        -e "s\" $FMCP_HOME\" fpath also-path" \
        -e "require fmcp_serve.4th" \
        -e "fmcp.serve-stdio" \
        -e "0 (bye)" 2>>"$stderr_dest"
    status=$?
    set -e
    if [ "$status" -ne 0 ]; then
        if [ -s "$stderr_dest" ]; then
            cat "$stderr_dest" >&2
        elif [ "$status" -eq 127 ]; then
            echo "[ERROR] fmcp serve: failed to start Gforth (GFORTH='${GFORTH}')." >&2
        fi
    fi
    exit "$status"
fi

if [ -z "$GFORTH_BIN" ]; then
    echo "[ERROR] fmcp: Gforth not found (GFORTH='${GFORTH}')." >&2
    exit 127
fi
set +e
"$GFORTH_BIN" \
    -e "s\" $FMCP_HOME\" fpath also-path" \
    "$FMCP_HOME/fmcp.4th"
status=$?
set -e
reset_tty
exit "$status"
